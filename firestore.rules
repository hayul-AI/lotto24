rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 시딩용 임시 허용 (시딩 후 write: if false로 복원 권장)
    match /lotto_results/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "medicalassistant9111@gmail.com";
    }
    match /pension_results/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "medicalassistant9111@gmail.com";
    }
    match /sync_status/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "medicalassistant9111@gmail.com";
    }
    
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
