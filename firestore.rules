rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "medicalassistant9111@gmail.com";
    }

    match /lotto_results/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pension_results/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sync_status/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lottery_stores/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /winning_stores/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
